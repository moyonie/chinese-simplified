{
    "name": "flarum-aifav/chinese-simplified",
    "description": "Simplified Chinese Language Pack for Flarum 2.0（有BUG，暂时不可用）",
    "type": "flarum-extension",
    "keywords": ["flarum", "locale", "extension", "chinese", "simplified", "简体中文"],
    "license": "MIT",
    "authors": [
        {
            "name": "AI Favorites Team",
            "email": "admin@aifav.cn",
            "homepage": "https://www.aifav.cn"
        }
    ],
    "support": {
        "issues": "https://github.com/flarum-aifav/chinese-simplified/issues",
        "source": "https://github.com/flarum-aifav/chinese-simplified",
        "forum": "https://discuss.flarum.org/d/22690"
    },
    "require": {
        "flarum/core": "^2.0.0-beta.8"
    },
    "replace": {
        "flarum-lang/chinese-simplified": "*"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.x-dev"
        },
        "flarum-extension": {
            "title": "简体中文",
            "category": "language",
            "icon": {
                "image": "icon.svg",
                "backgroundColor": "#ffffff",
                "backgroundSize": "cover",
                "backgroundPosition": "center"
            }
        },
        "extiverse": {
            "discuss": "https://discuss.flarum.org/d/22690"
        },
        "flarum-locale": {
            "code": "zh-Hans",
            "title": "简体中文"
        }
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
